# ── AUTH ──────────────────────────────────────────────────────────────────────
JWT_SECRET=                    # min 32 chars random — générer avec: openssl rand -hex 32
ALLOWED_ORIGINS=               # https://emploia.fr,https://emploia-clean.vercel.app

# ── ANTHROPIC ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=             # https://console.anthropic.com → API Keys

# ── UPSTASH REDIS (principal) ─────────────────────────────────────────────────
KV_REST_API_URL=               # https://console.upstash.com → Redis → REST API
KV_REST_API_TOKEN=             # Token principal (read/write)
KV_REST_API_READ_ONLY_TOKEN=   # Token lecture seule (optionnel mais recommandé)
KV_URL=                        # redis://... (pour compatibilité legacy)
REDIS_URL=                     # redis://... (alias)

# ── UPSTASH REDIS (storage — optionnel, fallback sur KV_REST_API_*) ───────────
STORAGE_KV_REST_API_URL=       # Laisser vide pour utiliser le même Redis
STORAGE_KV_REST_API_TOKEN=     # Laisser vide pour utiliser le même Redis

# ── STRIPE ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=             # sk_live_XXX (sk_test_XXX pour dev) — dashboard.stripe.com
STRIPE_WEBHOOK_SECRET=         # whsec_XXX — Stripe Dashboard → Webhooks → Signing secret
STRIPE_PRICE_PRO=              # price_XXX — Plan Pro mensuel (9€/mois)
STRIPE_PRICE_INTENSIF=         # price_XXX — Plan Intensif mensuel (19€/mois)
STRIPE_PRICE_PRO_ANNUAL=       # price_XXX — Plan Pro annuel (84€/an)
STRIPE_PRICE_INTENSIF_ANNUAL=  # price_XXX — Plan Intensif annuel (180€/an)

# ── EMAILS (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=                # https://resend.com → API Keys — gratuit 3 000/mois

# ── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=              # https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_SECRET=          # Même endroit que GOOGLE_CLIENT_ID

# ── JOBS APIs ─────────────────────────────────────────────────────────────────
RAPIDAPI_KEY=                  # https://rapidapi.com → JSearch API — gratuit 200 req/mois
ADZUNA_APP_ID=                 # https://developer.adzuna.com → Mes Apps
ADZUNA_APP_KEY=                # Même endroit que ADZUNA_APP_ID
FRANCE_TRAVAIL_CLIENT_ID=      # https://francetravail.io → Mes applications → API Offres v2
FRANCE_TRAVAIL_CLIENT_SECRET=  # Même endroit que FRANCE_TRAVAIL_CLIENT_ID

# ── SÉCURITÉ ──────────────────────────────────────────────────────────────────
CRON_SECRET=                   # Random string — générer avec: openssl rand -hex 24
HEALTH_SECRET=                 # Random string pour /api/health (mode détaillé)
ADMIN_SECRET=                  # Random string pour /api/admin et /admin/stats
VAPID_PUBLIC_KEY=              # Push notifs — générer avec: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=             # Même commande que VAPID_PUBLIC_KEY

# ── APP ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL=               # https://emploia.fr (ou https://ton-projet.vercel.app en dev)
