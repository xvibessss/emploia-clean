<!doctype html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>EmploiA — Le copilote IA français pour décrocher vos entretiens</title>
<meta name="description" content="EmploiA adapte votre CV à chaque offre, suit vos candidatures et vous prépare aux entretiens. 800 000 offres françaises. Score ATS en 30 secondes."/>
<meta name="google-site-verification" content="IqZoXqFuYcnkKhElhGYpdqdTrTd8hKzDLue-1M47pDA"/>
<link rel="canonical" href="https://emploia.fr/"/>
<link rel="icon" href="favicon.svg"/>
<link rel="manifest" href="manifest.json"/>
<meta name="theme-color" content="#0E1830"/>
<meta property="og:title" content="EmploiA — Le copilote IA français"/>
<meta property="og:description" content="CV adapté à chaque offre, lettre de motivation, score ATS — en 30 secondes."/>
<meta property="og:image" content="https://emploia.fr/og-image.svg"/>
<meta property="og:type" content="website"/>
<meta property="og:url" content="https://emploia.fr/"/>
<meta name="twitter:card" content="summary_large_image"/>
<link rel="stylesheet" href="shared.css"/>

<style>
/* ─── Page-specific (mockup, sticky-notes, feature visuals) ─── */

/* Workspace mockup inside hero */
.mk-top{display:flex;align-items:center;gap:8px;padding:12px 14px;border-bottom:1px solid var(--hairline-soft);background:var(--surface-soft)}
.mk-top .tl{width:11px;height:11px;border-radius:50%}
.mk-top .url{margin-left:12px;font-size:12px;color:var(--steel);background:#fff;border:1px solid var(--hairline);padding:4px 10px;border-radius:6px}
.mk-body{display:grid;grid-template-columns:220px 1fr;min-height:480px}
.mk-side{background:#FBFAF7;border-right:1px solid var(--hairline-soft);padding:14px 10px;font-size:13px}
.mk-side .ws{display:flex;align-items:center;gap:8px;padding:6px 8px;font-weight:600;color:var(--ink)}
.mk-side .ws .av{width:20px;height:20px;border-radius:5px;background:var(--brand-purple);color:#fff;display:grid;place-items:center;font-size:10px;font-weight:700}
.mk-side .sec{margin-top:14px;color:var(--steel);font-size:11px;text-transform:uppercase;letter-spacing:.5px;padding:0 8px 6px}
.mk-side .it{display:flex;align-items:center;gap:8px;padding:5px 8px;border-radius:5px;color:var(--charcoal);font-size:13px}
.mk-side .it.on{background:var(--surface)}
.mk-side .it svg{flex-shrink:0}
.mk-main{padding:22px 28px}
.mk-crumb{font-size:12px;color:var(--steel);margin-bottom:18px}
.mk-title{font-size:30px;font-weight:700;color:var(--ink);margin:0 0 6px;letter-spacing:-.5px}
.mk-sub{font-size:13px;color:var(--steel);margin-bottom:18px}
.mk-tabs{display:flex;gap:18px;border-bottom:1px solid var(--hairline-soft);margin-bottom:16px;font-size:13px;color:var(--steel)}
.mk-tabs span{padding:8px 0}
.mk-tabs span.on{color:var(--ink);border-bottom:2px solid var(--ink);font-weight:600;margin-bottom:-1px}

.kanban{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.kcol .kh{font-size:12px;font-weight:600;color:var(--charcoal);display:flex;align-items:center;gap:6px;padding:4px 0 10px}
.kcol .kh .pl{font-size:11px;color:var(--slate);background:var(--surface);border-radius:4px;padding:1px 6px;font-weight:500}
.kcard{background:var(--canvas);border:1px solid var(--hairline);border-radius:8px;padding:10px 12px;margin-bottom:10px;font-size:13px;color:var(--charcoal);box-shadow:rgba(15,15,15,.03) 0 1px 2px}
.kcard .meta{display:flex;align-items:center;justify-content:space-between;margin-top:8px;color:var(--steel);font-size:11px}
.kcard .av{display:inline-block;width:18px;height:18px;border-radius:50%;color:#fff;font-size:9px;font-weight:700;text-align:center;line-height:18px}
@media (max-width:767px){.mk-body{grid-template-columns:1fr}.mk-side{display:none}.kanban{grid-template-columns:1fr 1fr;overflow-x:auto}}

/* Sticky panel + notes board */
.sticky-panel{background:var(--canvas);border-radius:var(--r-xl);border:1px solid var(--hairline);padding:56px 48px;box-shadow:var(--sh-2);overflow:hidden;position:relative}
.sticky-panel .grid{display:grid;grid-template-columns:1.1fr 1fr;gap:48px;align-items:center}
.status-list{display:flex;flex-direction:column;gap:10px}
.status-item{display:flex;align-items:center;gap:12px;padding:12px 14px;background:var(--surface-soft);border:1px solid var(--hairline-soft);border-radius:8px;font-size:14px;font-weight:500;color:var(--charcoal)}
.status-ic{width:22px;height:22px;border-radius:6px;display:grid;place-items:center;color:#fff;flex-shrink:0;font-size:13px;font-weight:700}
.status-time{margin-left:auto;font-size:12px;color:var(--steel);font-weight:500}
.notes-board{position:relative;height:380px}
.note{position:absolute;background:var(--tint-yellow);border-radius:6px;padding:14px 16px;font-size:13px;line-height:1.4;color:var(--charcoal);box-shadow:rgba(0,0,0,.1) 0 6px 14px -2px;width:200px}
.note strong{display:block;font-weight:600;margin-bottom:4px;font-size:13px;color:var(--ink)}
.note .who{font-size:11px;color:var(--steel);margin-top:8px;font-weight:500}
@media (max-width:767px){.sticky-panel{padding:32px 22px}.sticky-panel .grid{grid-template-columns:1fr;gap:32px}.notes-board{height:auto;display:grid;grid-template-columns:1fr 1fr;gap:14px}.note{position:static!important;transform:none!important;width:auto!important}}

/* Yellow banner with chat */
.assist-banner{display:grid;grid-template-columns:1.2fr 1fr;gap:48px;align-items:center}
.assist-visual{background:#fff;border-radius:var(--r-lg);padding:18px;box-shadow:var(--sh-2)}
.assist-row{display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:1px solid var(--hairline-soft);font-size:13px}
.assist-row:last-child{border-bottom:0}
.assist-row .av{width:28px;height:28px;border-radius:7px;background:var(--primary);color:#fff;display:grid;place-items:center;font-weight:700;font-size:13px;flex-shrink:0}
.assist-row .av.user{background:var(--brand-orange)}
.assist-row .txt{color:var(--charcoal);line-height:1.5}
.assist-row .txt strong{font-weight:600;color:var(--ink)}
.chip-tag{font-size:13px;font-weight:600;padding:5px 11px;border-radius:6px;background:rgba(0,0,0,.08);color:var(--ink)}
@media (max-width:1023px){.assist-banner{grid-template-columns:1fr}}

/* Tiles + viz */
.tiles{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:24px}
.tile h4{margin:0 0 8px;font-size:22px;font-weight:600;color:var(--ink);letter-spacing:-.3px}
.tile p{margin:0;font-size:14px;color:var(--slate);line-height:1.5}
.tile{display:flex;flex-direction:column;min-height:280px}
.tile .viz{margin-top:auto;padding-top:20px}
.mini-card{background:#fff;border-radius:8px;padding:12px 14px;font-size:12px;color:var(--charcoal);box-shadow:rgba(0,0,0,.05) 0 2px 6px}
.mini-card .ttl{font-weight:600;color:var(--ink);margin-bottom:4px;font-size:13px}
.mini-card .lbl{font-size:10px;color:var(--steel);text-transform:uppercase;letter-spacing:.4px}
@media (max-width:1023px){.tiles{grid-template-columns:1fr 1fr}}
@media (max-width:767px){.tiles{grid-template-columns:1fr}}

/* Bring grid */
.bring-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.bring-card{border-radius:var(--r-lg);padding:32px;color:var(--charcoal);display:flex;flex-direction:column;min-height:380px}
.bring-card h4{margin:0 0 10px;font-size:22px;font-weight:600;color:var(--ink);letter-spacing:-.3px}
.bring-card p{margin:0;font-size:14px;color:var(--slate)}
.bring-card .viz{margin-top:auto;padding-top:24px}
.tut-card{background:#fff;border-radius:8px;padding:14px;box-shadow:rgba(0,0,0,.06) 0 4px 10px}
.tut-thumb{aspect-ratio:16/10;background:linear-gradient(135deg,#0E1830,#2A3658);border-radius:6px;position:relative;margin-bottom:10px;overflow:hidden}
.tut-thumb .play{position:absolute;inset:0;display:grid;place-items:center;color:#fff}
.tut-thumb .play div{width:46px;height:46px;border-radius:50%;background:rgba(255,255,255,.95);display:grid;place-items:center;color:var(--ink-deep)}
.tut-thumb .deco{position:absolute;width:18px;height:18px;border-radius:4px}
.cal-card{background:#fff;border-radius:8px;padding:14px;box-shadow:rgba(0,0,0,.06) 0 4px 10px;font-size:11px;color:var(--charcoal)}
.cal-card .day{font-size:10px;color:var(--steel);text-transform:uppercase;letter-spacing:.4px;margin-bottom:8px}
.cal-row{display:flex;align-items:center;gap:6px;padding:5px 7px;border-radius:5px;margin-bottom:3px;font-size:11px}
.cal-row .clr{width:3px;height:14px;border-radius:2px;flex-shrink:0}
.quote-card{font-size:18px;line-height:1.5;color:#fff;font-weight:500}
.quote-attr{display:flex;align-items:center;gap:10px;margin-top:18px;font-size:13px;color:rgba(255,255,255,.85)}
.quote-attr .av{width:32px;height:32px;border-radius:50%;background:var(--brand-orange)}
@media (max-width:1023px){.bring-grid{grid-template-columns:1fr 1fr}}
@media (max-width:767px){.bring-grid{grid-template-columns:1fr}}

/* Comparison grid override */
.cmp{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr 1fr}
@media (max-width:767px){.cmp{grid-template-columns:1.4fr repeat(4, 80px);min-width:560px}.emp-compare{overflow-x:auto}}

/* Testi grid */
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
@media (max-width:900px){.testi-grid{grid-template-columns:1fr}}
</style>
</head>
<body>

<div id="emp-scroll-prog"></div>

<!-- ═════ PROMO BANNER ═════ -->
<div class="emp-promo">
  Nouveau : extension LinkedIn — analysez n'importe quelle offre en 1 clic <span class="arrow">→</span>
</div>

<!-- ═════ NAV ═════ -->
<header class="emp-nav">
  <div class="container emp-nav-inner">
    <div style="display:flex;align-items:center;gap:36px">
      <a href="/" class="emp-brand">
        <span class="emp-brand-mark" aria-hidden="true"><svg viewBox="0 0 64 64" fill="currentColor"><rect x="8" y="10" width="48" height="12" rx="3.5"/><rect x="8" y="26" width="34" height="12" rx="3.5"/><rect x="8" y="42" width="48" height="12" rx="3.5"/></svg></span>
        EmploiA
      </a>
      <nav class="emp-nav-links">
        <a href="jobs.html">Offres</a>
        <a href="app.html">Générateur CV</a>
        <a href="interview.html">Coach IA</a>
        <a href="dashboard.html">Tableau de bord</a>
        <a href="blog.html">Ressources</a>
        <a href="#pricing">Tarifs</a>
        <a href="#contact">Demander une démo</a>
      </nav>
    </div>
    <div class="emp-nav-right">
      <a href="app.html" class="emp-btn emp-btn-ghost emp-login">Se connecter</a>
      <a href="app.html" class="emp-btn emp-btn-primary">Essayer gratuitement</a>
      <button class="emp-hamburger" id="empHamburger" onclick="empToggleNav()" aria-label="Menu"><span></span></button>
    </div>
  </div>
</header>
<nav class="emp-mobile-nav" id="empMobileNav">
  <a href="jobs.html">Offres</a>
  <a href="app.html">Générateur CV</a>
  <a href="interview.html">Coach IA</a>
  <a href="dashboard.html">Tableau de bord</a>
  <a href="blog.html">Ressources</a>
  <a href="#pricing">Tarifs</a>
  <a href="app.html">Se connecter</a>
</nav>

<!-- ═════ HERO ═════ -->
<section class="emp-hero-dark">
  <!-- Decorative dots -->
  <div class="emp-dot lg" style="--r:-8deg;background:var(--brand-pink);top:120px;left:8%"></div>
  <div class="emp-dot sm" style="--r:14deg;background:var(--brand-orange);top:60px;left:24%"></div>
  <div class="emp-dot lg" style="--r:6deg;background:var(--brand-yellow);top:90px;right:9%"></div>
  <div class="emp-dot sm" style="--r:-12deg;background:var(--brand-teal);top:200px;right:22%"></div>
  <div class="emp-dot sm" style="--r:18deg;background:var(--brand-green);bottom:280px;left:14%"></div>
  <div class="emp-dot lg" style="--r:-4deg;background:var(--brand-purple);bottom:320px;right:6%"></div>
  <div class="emp-dot sm" style="--r:8deg;background:var(--brand-pink);bottom:230px;right:34%"></div>

  <!-- Mesh wires -->
  <svg class="emp-wire" style="top:40px;left:3%;width:240px;height:160px" viewBox="0 0 240 160" fill="none">
    <path d="M10 80 Q 60 10, 120 80 T 230 80" stroke="#fff" stroke-width="1.2" opacity=".4"/>
    <path d="M10 100 Q 60 30, 120 100 T 230 100" stroke="#fff" stroke-width="1.2" opacity=".25"/>
  </svg>
  <svg class="emp-wire" style="top:140px;right:4%;width:220px;height:200px" viewBox="0 0 220 200" fill="none">
    <path d="M210 20 Q 140 60, 180 130 T 100 180" stroke="#fff" stroke-width="1.2" opacity=".4"/>
    <path d="M210 40 Q 130 80, 170 150 T 80 195" stroke="#fff" stroke-width="1.2" opacity=".25"/>
  </svg>

  <div class="emp-hero-inner">
    <h1 class="t-hero">Le copilote qui<br/>candidate à votre place.</h1>
    <p class="emp-hero-sub">Un CV taillé pour chaque offre, des entretiens préparés, un suivi de candidatures — en français, dans un seul espace.</p>
    <div class="emp-hero-cta">
      <a href="app.html" class="emp-btn emp-btn-primary">Essayer EmploiA gratuitement</a>
      <a href="#contact" class="emp-btn emp-btn-sec-on-dark">Demander une démo</a>
    </div>
  </div>

  <!-- Workspace mockup card -->
  <div class="emp-hero-mockup-wrap">
    <div class="emp-mockup-card">
      <div class="mk-top">
        <span class="tl" style="background:#FF5F57"></span>
        <span class="tl" style="background:#FEBC2E"></span>
        <span class="tl" style="background:#28C840"></span>
        <span class="url">emploia.fr/espace/camille-durand</span>
      </div>
      <div class="mk-body">
        <aside class="mk-side">
          <div class="ws"><span class="av">C</span>Camille Durand</div>
          <div class="sec">Mon espace</div>
          <div class="it on"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/></svg>Tableau de bord</div>
          <div class="it"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>Mes CV</div>
          <div class="it"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>Lettres de motivation</div>
          <div class="it"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>Entretiens</div>
          <div class="sec">Suivi</div>
          <div class="it"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>Candidatures</div>
          <div class="it"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>Statistiques</div>
        </aside>
        <main class="mk-main">
          <div class="mk-crumb">Mon espace / Candidatures / Printemps 2026</div>
          <h2 class="mk-title">🎯 Campagne candidatures</h2>
          <div class="mk-sub">12 offres ciblées · Mise à jour il y a 4 minutes</div>
          <div class="mk-tabs">
            <span class="on">Tableau</span>
            <span>Liste</span>
            <span>Calendrier</span>
            <span>Statistiques</span>
          </div>
          <div class="kanban">
            <div class="kcol">
              <div class="kh">À candidater <span class="pl">4</span></div>
              <div class="kcard"><span class="emp-tag emp-tag-orange">Product</span><div>Senior PM — Doctolib</div><div class="meta"><span>📍 Paris</span><span class="av" style="background:var(--brand-orange)">M</span></div></div>
              <div class="kcard"><span class="emp-tag emp-tag-green">Design</span><div>UX Lead — Alan</div><div class="meta"><span>🏡 Remote</span><span class="av" style="background:var(--brand-green)">L</span></div></div>
              <div class="kcard"><span class="emp-tag emp-tag-purple">Data</span><div>Data Scientist — Qonto</div><div class="meta"><span>📍 Lyon</span><span class="av" style="background:var(--brand-purple)">A</span></div></div>
            </div>
            <div class="kcol">
              <div class="kh">CV en cours <span class="pl">3</span></div>
              <div class="kcard"><span class="emp-tag emp-tag-sky">Marketing</span><div>Growth — Swile</div><div class="meta"><span>Score ATS 87%</span><span class="av" style="background:var(--brand-teal)">J</span></div></div>
              <div class="kcard"><span class="emp-tag emp-tag-orange">Product</span><div>PM Junior — Back Market</div><div class="meta"><span>Score ATS 91%</span><span class="av" style="background:var(--brand-orange)">M</span></div></div>
              <div class="kcard"><span class="emp-tag emp-tag-rose">RH</span><div>Talent — Mirakl</div><div class="meta"><span>Score ATS 78%</span><span class="av" style="background:var(--brand-pink)">S</span></div></div>
            </div>
            <div class="kcol">
              <div class="kh">Envoyées <span class="pl">3</span></div>
              <div class="kcard"><span class="emp-tag emp-tag-yellow">Sales</span><div>AE — Pennylane</div><div class="meta"><span>Il y a 2 j.</span><span class="av" style="background:var(--brand-yellow)">N</span></div></div>
              <div class="kcard"><span class="emp-tag emp-tag-purple">Data</span><div>Analyste — Veepee</div><div class="meta"><span>Il y a 5 j.</span><span class="av" style="background:var(--brand-purple)">A</span></div></div>
            </div>
            <div class="kcol">
              <div class="kh">Entretien <span class="pl">2</span></div>
              <div class="kcard"><span class="emp-tag emp-tag-green">Design</span><div>Product Designer — Payfit</div><div class="meta"><span>Jeu. 14h</span><span class="av" style="background:var(--brand-green)">L</span></div></div>
              <div class="kcard"><span class="emp-tag emp-tag-sky">Marketing</span><div>Brand Lead — Blablacar</div><div class="meta"><span>Lun. 10h</span><span class="av" style="background:var(--brand-teal)">J</span></div></div>
            </div>
          </div>
        </main>
      </div>
    </div>
  </div>
</section>

<!-- ═════ LOGO WALL ═════ -->
<section class="emp-logo-wall" style="padding-top:160px">
  <div class="container">
    <div class="lbl">Approuvé par des candidats reçus chez</div>
    <div class="row">
      <span>Doctolib</span><span>Qonto</span><span>Alan</span><span>BlaBlaCar</span><span>Swile</span><span>Pennylane</span><span>Back Market</span>
    </div>
  </div>
</section>

<!-- ═════ STICKY-NOTE PANEL ═════ -->
<section class="emp-section">
  <div class="container">
    <div class="sticky-panel">
      <div class="grid">
        <div>
          <h2 class="t-h2">Gardez vos candidatures<br/>en mouvement, 24/7.</h2>
          <p class="t-subtitle mt-4">Chaque offre que vous ajoutez est analysée, scorée et préparée pendant que vous dormez. Au réveil, votre CV est prêt à envoyer.</p>
          <div class="status-list mt-6">
            <div class="status-item">
              <span class="status-ic" style="background:var(--brand-pink)">✓</span>
              CV adapté à&nbsp;<strong style="font-weight:600">Senior PM — Doctolib</strong>
              <span class="status-time">Il y a 3 min</span>
            </div>
            <div class="status-item">
              <span class="status-ic" style="background:var(--link-blue)">↻</span>
              Lettre de motivation générée
              <span class="status-time">Il y a 12 min</span>
            </div>
            <div class="status-item">
              <span class="status-ic" style="background:var(--brand-green)">▲</span>
              Score ATS amélioré&nbsp;<strong style="font-weight:600">+14%</strong>
              <span class="status-time">Cette nuit</span>
            </div>
            <div class="status-item">
              <span class="status-ic" style="background:var(--primary)">✦</span>
              3 nouvelles offres correspondantes
              <span class="status-time">Ce matin</span>
            </div>
            <div class="status-item">
              <span class="status-ic" style="background:var(--brand-teal)">◆</span>
              Préparation d'entretien — Payfit
              <span class="status-time">Prête</span>
            </div>
          </div>
        </div>
        <div class="notes-board">
          <div class="note" style="background:var(--tint-yellow);top:0;left:20px;transform:rotate(-6deg)">
            <strong>Relancer Doctolib</strong>
            10 jours sans nouvelle. EmploiA propose un message court et sympa.
            <div class="who">Reco IA · ce matin</div>
          </div>
          <div class="note" style="background:var(--tint-rose);top:30px;right:0;transform:rotate(5deg)">
            <strong>Question piège possible</strong>
            "Pourquoi quitter votre poste actuel ?" — 3 réponses préparées.
            <div class="who">Coach IA</div>
          </div>
          <div class="note" style="background:var(--tint-mint);top:200px;left:0;transform:rotate(-3deg)">
            <strong>Mot-clé manquant</strong>
            Ajoutez "roadmap discovery" sur le CV Qonto.
            <div class="who">Optim. ATS</div>
          </div>
          <div class="note" style="background:var(--tint-sky);top:180px;right:40px;transform:rotate(7deg)">
            <strong>Entretien jeudi 14h</strong>
